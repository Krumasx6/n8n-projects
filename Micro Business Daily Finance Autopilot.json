    {
      "parameters": {
        "sendTo": "raizorain48@gmail.com",
        "subject": "=Daily Finance Report - {{ $json.Date }}",
        "message": "=<div style=\"font-family: Arial; padding: 20px; background: linear-gradient(135deg, #f5f5f5, #eef2ff);\">\n  <div style=\"max-width: 650px; margin: auto; background: white; padding: 0; border-radius: 14px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.08);\">\n\n    <!-- HEADER -->\n    <div style=\"background: #111827; color: white; padding: 18px 22px;\">\n      <h2 style=\"margin: 0; font-size: 20px;\">📊 Daily Business Report</h2>\n      <p style=\"margin: 5px 0 0; opacity: 0.7;\">{{ $json.Date }}</p>\n    </div>\n\n    <!-- SUMMARY GRID -->\n    <div style=\"display: flex; justify-content: space-between; padding: 20px; gap: 10px;\">\n      <div style=\"flex:1; background:#f9fafb; padding:12px; border-radius:10px;\">\n        <p style=\"margin:0; font-size:12px; color:#6b7280;\">Sales</p>\n        <p style=\"margin:6px 0 0; font-size:18px; font-weight:bold;\">₱{{ $json.Sales }}</p>\n      </div>\n      <div style=\"flex:1; background:#f9fafb; padding:12px; border-radius:10px;\">\n        <p style=\"margin:0; font-size:12px; color:#6b7280;\">Expenses</p>\n        <p style=\"margin:6px 0 0; font-size:18px; font-weight:bold;\">₱{{ $json.Expenses }}</p>\n      </div>\n      <div style=\"flex:1; background:#f9fafb; padding:12px; border-radius:10px;\">\n        <p style=\"margin:0; font-size:12px; color:#6b7280;\">Net Profit</p>\n        <p style=\"margin:6px 0 0; font-size:18px; font-weight:bold;\">₱{{ $json[\"Net Profit\"] }}</p>\n      </div>\n    </div>\n\n    <!-- DIVIDER -->\n    <div style=\"height:1px; background:#e5e7eb;\"></div>\n\n    <!-- ALLOCATIONS -->\n    <div style=\"padding: 20px;\">\n      <h3 style=\"margin: 0 0 12px;\">📦 Allocations</h3>\n      <div style=\"background:#f9fafb; padding:12px; border-radius:10px; margin-bottom:8px;\">\n        Materials (15%): <b>₱{{ $json.Materials }}</b>\n      </div>\n      <div style=\"background:#f9fafb; padding:12px; border-radius:10px; margin-bottom:8px;\">\n        Savings (10%): <b>₱{{ $json.Savings }}</b>\n      </div>\n      <div style=\"background:#f9fafb; padding:12px; border-radius:10px;\">\n        Emergency (5%): <b>₱{{ $json.Emergency }}</b>\n      </div>\n    </div>\n\n    <!-- STATUS -->\n    <div style=\"padding: 20px; text-align:center; border-top:1px solid #eee;\">\n      <span style=\"\n        display:inline-block;\n        padding:10px 28px;\n        border-radius:999px;\n        font-weight:bold;\n        font-size:15px;\n        background: {{ $json.Status === 'Normal' ? '#dcfce7' : '#fee2e2' }};\n        color: {{ $json.Status === 'Normal' ? '#166534' : '#991b1b' }};\n      \">\n        {{ $json.Status }}\n      </span>\n    </div>\n\n  </div>\n</div>",
