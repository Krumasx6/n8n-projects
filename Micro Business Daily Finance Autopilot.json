    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst sales = Number(item.sales) || 0;\nconst expenses = Number(item.expenses) || 0;\nconst materials_alloc = Math.round(sales * 0.15);\nconst savings_alloc = Math.round(sales * 0.10);\nconst emergency_alloc = Math.round(sales * 0.05);\nconst net_profit = sales - expenses - materials_alloc - savings_alloc - emergency_alloc;\nconst status = net_profit >= 0 ? \"Normal\" : \"Loss\";\nconst statusColor = status === \"Normal\" ? \"#166534\" : \"#991b1b\";\nconst statusBg = status === \"Normal\" ? \"#dcfce7\" : \"#fee2e2\";\nreturn [\n  {\n    json: {\n      ...item,\n      Materials: materials_alloc,\n      Savings: savings_alloc,\n      Emergency: emergency_alloc,\n      \"Net Profit\": net_profit,\n      Status: status,\n      statusColor,\n      statusBg,\n      Reported: item.reported\n    }\n  }\n];"
      },
